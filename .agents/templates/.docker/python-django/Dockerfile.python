# ==========================================
# ESTAGIO 1: BASE E DEPENDENCIAS (CACHE)
# ==========================================
FROM python:3.12-slim AS base

LABEL maintainer="Ambiente python django"
LABEL description="Ambiente de desenvolvimento Python para Django usando UV"

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Dependencia de runtime do psycopg2-binary
RUN apt-get update && \
    apt-get install -y --no-install-recommends libpq5 && \
    rm -rf /var/lib/apt/lists/*

# Usa uv como instalador principal de dependencias Python
RUN pip install --no-cache-dir uv

# Copiamos o manifesto para aproveitar cache de layer
COPY pyproject.toml ./

# Somente dependencias realmente usadas pelos scripts atuais
RUN uv pip install --system --no-cache \
    pandas \
    psycopg2-binary \
    python-dotenv

# ==========================================
# ESTAGIO 2: DESENVOLVIMENTO (DevContainer)
# ==========================================
FROM base AS dev

EXPOSE 8000

# Como o código vem via Bind Mount do compose, mantemos o servidor rodando.
# Se as dependências não estão no build cache, o container aguarda a instalação.
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]

# ==========================================
# ESTAGIO 3: PRODUCAO (Deploy)
# ==========================================
FROM base AS prod

# Cópia do código
COPY . .

# Comando de produção padrão (Mude para gunicorn/uvicorn apropriadamente)
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
